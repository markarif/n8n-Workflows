      "parameters": {
        "jsCode": "// Get the question typed in the chat UI\nconst question = $('When Chat Message Received').first().json.chatInput || '';\n\n// All knowledge base chunks come in as individual items\nconst allChunks = $input.all().map(i => i.json);\n\nif (allChunks.length === 0) {\n  return [{\n    json: {\n      question,\n      context: 'The knowledge base is empty. Please run the Bulk Ingestion workflow first.',\n      chunksFound: 0\n    }\n  }];\n}\n\n// Tokenise the question — skip very short/common words\nconst questionWords = question\n  .toLowerCase()\n  .split(/\\W+/)\n  .filter(w => w.length > 2);\n\n// Score each chunk by how many question words it contains\nconst scored = allChunks.map(chunk => {\n  const text  = (chunk.ChunkText || '').toLowerCase();\n  const score = questionWords.reduce((acc, word) => acc + (text.includes(word) ? 1 : 0), 0);\n  return { ...chunk, score };\n});\n\n// Take the top 5 most relevant chunks\nconst top5 = scored\n  .filter(c => c.score > 0)\n  .sort((a, b) => b.score - a.score)\n  .slice(0, 5);\n\n// Fall back to first 3 chunks if nothing matched\nconst chunksToUse = top5.length > 0 ? top5 : allChunks.slice(0, 3);\n\n// Format as a readable context block for the AI\nconst context = chunksToUse\n  .map((c, i) => `[${i + 1}] Document: ${c.DocumentName} | ${c.Section}\\n${c.ChunkText}`)\n  .join('\\n\\n---\\n\\n');\n\nreturn [{ json: { question, context, chunksFound: top5.length } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
