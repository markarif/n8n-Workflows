      "parameters": {
        "jsCode": "// Get the list of already-ingested document names (from the collapsed single item)\nconst existingNames = new Set(\n  $('Collapse to Unique Doc Names').first().json.existingDocNames || []\n);\n\n// Filter Drive PDFs to only ones not already in the knowledge base\nconst newPDFs = $input.all().filter(item => {\n  const fileName = (item.json.name || '').toLowerCase().trim();\n  return !existingNames.has(fileName);\n});\n\nconsole.log(`PDFs in Drive: ${$input.all().length}`);\nconsole.log(`Already ingested: ${existingNames.size}`);\nconsole.log(`New to process: ${newPDFs.length}`);\nif (newPDFs.length > 0) {\n  console.log(`Will ingest: ${newPDFs.map(i => i.json.name).join(', ')}`);\n}\n\nif (newPDFs.length === 0) {\n  return [{ json: { noNewDocuments: true, message: 'All documents are already in the knowledge base.' } }];\n}\n\nreturn newPDFs;"
      },
