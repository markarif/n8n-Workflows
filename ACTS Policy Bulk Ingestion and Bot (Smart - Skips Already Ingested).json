    {
      "parameters": {
        "jsCode": "// Loop over all PDFs — chunk each one\nconst results = [];\nconst skipped = [];\n\nfor (const item of $input.all()) {\n  const text     = item.json.text     || '';\n  const fileName = item.json.fileName || 'Unknown Document';\n\n  // Skip PDFs with no extractable text (scanned image PDFs)\n  if (!text.trim()) {\n    skipped.push(fileName);\n    console.log(`SKIPPED (no text): ${fileName} — this is likely a scanned image PDF. Convert it to text-based PDF and re-run.`);\n    continue;\n  }\n\n  const words     = text.split(/\\s+/).filter(w => w.length > 0);\n  const chunkSize = 500;\n  const overlap   = 50;\n\n  let i          = 0;\n  let chunkIndex = 1;\n\n  while (i < words.length) {\n    const chunkWords    = words.slice(i, i + chunkSize);\n    const chunkText     = chunkWords.join(' ');\n    const estimatedPage = Math.ceil((i + 1) / 250);\n\n    results.push({\n      json: {\n        DocumentName: fileName,\n        Section:      'Page ~' + estimatedPage,\n        PageNumber:   String(estimatedPage),\n        ChunkText:    chunkText,\n        ChunkIndex:   chunkIndex,\n        WordCount:    chunkWords.length\n      }\n    });\n\n    i += chunkSize - overlap;\n    chunkIndex++;\n  }\n\n  console.log(`Chunked: ${fileName} → ${chunkIndex - 1} chunks`);\n}\n\nif (skipped.length > 0) {\n  console.log(`Skipped ${skipped.length} scanned PDFs: ${skipped.join(', ')}`);\n}\n\n// If ALL PDFs were scanned and nothing was chunked, return a status item\n// so the workflow ends cleanly instead of crashing\nif (results.length === 0) {\n  return [{ json: {\n    status: 'no_text_extracted',\n    message: `All PDFs were skipped. Scanned PDFs found: ${skipped.join(', ')}. Please convert these to text-based PDFs.`,\n    skippedFiles: skipped\n  }}];\n}\n\nreturn results;"
      },
